# --- Core ---
DATABASE_URL=file:./dev.db
SESSION_SECRET=                     # >=32 chars (openssl rand -base64 48)
ENCRYPTION_KEY=                     # 64 hex chars (openssl rand -hex 32)

# --- Optional platform fallback keys (per-profile BYOK overrides these in app) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
XAI_API_KEY=
FIREWORKS_API_KEY=
OPENROUTER_API_KEY=
TAVILY_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Sandbox (off by default) ---
OPENMLC_SANDBOX_ENABLED=false
OPENMLC_SANDBOX_DOCKER_HOST=

