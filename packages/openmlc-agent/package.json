{
  "name": "openmlc-agent",
  "version": "0.1.0",
  "description": "Host-machine control daemon for OpenMLC computer agent mode.",
  "bin": {
    "openmlc-agent": "./dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --format=cjs --banner:js='#!/usr/bin/env node'",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "files": ["dist"],
  "dependencies": {
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "systeminformation": "^5.23.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.2",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["openmlc", "computer-use", "ai", "agent"],
  "license": "FSL-1.1-Apache-2.0"
}
