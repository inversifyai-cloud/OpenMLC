# OpenMLC — Docker env template.
# Copy to .env, fill in the two required secrets, then `docker compose up -d`.

# REQUIRED — iron-session cookie secret. Min 32 chars.
# Generate: openssl rand -hex 32
SESSION_SECRET=

# REQUIRED — symmetric key for encrypting stored provider API keys at rest.
# Must be a 64-char hex string (= 32 bytes).
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# Optional — pre-fill any provider API keys you don't want users to paste.
# (Users can also add these from /settings/api-keys after first run.)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# GOOGLE_API_KEY=
# XAI_API_KEY=
# FIREWORKS_API_KEY=

# Optional — for the OpenAI-compatible /v1/chat/completions endpoint.
# When set, requires this exact bearer token; when unset, anyone with
# network access to the container can hit /v1/* (fine for trusted LANs).
# OPENMLC_API_KEY=
